# API Keys (Get free keys from respective providers)
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_token_here

# LangSmith Monitoring (Optional - Free tier available)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=enterprise-rag-system

# Model Configuration
DEFAULT_LLM_PROVIDER=groq  # Options: openai, groq, huggingface
DEFAULT_LLM_MODEL=llama3-70b-8192  # For Groq
# DEFAULT_LLM_MODEL=gpt-3.5-turbo  # For OpenAI
EMBEDDING_MODEL=all-mpnet-base-v2
MAX_TOKENS=8192
TEMPERATURE=0.7

# Vector Database
VECTOR_DB_TYPE=chromadb  # Options: chromadb, faiss
VECTOR_DB_PATH=./data/vector_db
COLLECTION_NAME=documents

# Document Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_CHUNKS_PER_DOC=1000

# Retrieval Configuration
TOP_K_RESULTS=10
RERANK_TOP_K=5
SIMILARITY_THRESHOLD=0.7

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8501"]

# Security
SECRET_KEY=your_secret_key_here_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=500

# Caching
ENABLE_CACHE=true
CACHE_TYPE=disk  # Options: disk, redis, memory
CACHE_DIR=./data/cache
CACHE_TTL=3600  # seconds
REDIS_URL=redis://localhost:6379

# Frontend
STREAMLIT_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# Logging
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=./logs/app.log

# Development
DEBUG=false
RELOAD=false

# Performance
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=300  # seconds

# File Upload
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=[".pdf", ".docx", ".txt", ".md"]
