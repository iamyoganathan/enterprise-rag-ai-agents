# Streamlit Cloud Secrets Configuration
# After deploying to Streamlit Cloud, add these secrets in the dashboard

# You'll set these in: https://share.streamlit.io/
# App Settings → Secrets

# Example format (don't commit this file with real values!):
# API_BASE_URL = "https://your-backend.onrender.com"
# GROQ_API_KEY = "your_groq_key_here"
